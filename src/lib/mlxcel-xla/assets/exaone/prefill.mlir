      %209 = stablehlo.compare LT, %ami_l, %ami_r, SIGNED : (tensor<i32>, tensor<i32>) -> tensor<i1>
      %210 = stablehlo.and %208, %209 : tensor<i1>
      %211 = stablehlo.or %207, %210 : tensor<i1>
      %212 = stablehlo.select %207, %amv_l, %amv_r : tensor<i1>, tensor<f32>
      %213 = stablehlo.select %211, %ami_l, %ami_r : tensor<i1>, tensor<i32>
      stablehlo.return %212, %213 : tensor<f32>, tensor<i32>
    }
    return %204#1, %142, %144 : tensor<i32>, tensor<2x256x1x4xf32>, tensor<2x256x1x4xf32>
  }
