      %205 = stablehlo.compare LT, %ami_l, %ami_r, SIGNED : (tensor<i32>, tensor<i32>) -> tensor<i1>
      %206 = stablehlo.and %204, %205 : tensor<i1>
      %207 = stablehlo.or %203, %206 : tensor<i1>
      %208 = stablehlo.select %203, %amv_l, %amv_r : tensor<i1>, tensor<f32>
      %209 = stablehlo.select %207, %ami_l, %ami_r : tensor<i1>, tensor<i32>
      stablehlo.return %208, %209 : tensor<f32>, tensor<i32>
    }
    return %200#1, %142, %144 : tensor<i32>, tensor<2x256x1x4xf32>, tensor<2x256x1x4xf32>
  }
}
